# Copy to .env and fill in. NEVER commit your real .env.

# ---- Neo4j (required for graph writes / reasoning) ----
# Neo4j Aura: get these from console.neo4j.io. Note that on Aura the database
# name is often the instance id, NOT "neo4j" — copy it exactly from the console.
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j

# ---- OpenAI (required: browser-use drives the crawl with an LLM) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: point the OpenAI SDK at a compatible proxy/gateway. The openai SDK
# reads this from the environment automatically.
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Target ----
# Default product if --url is not passed.
TARGET_PRODUCT_URL=https://www.amazon.com/dp/0307887898

# Amazon login is done interactively in a real browser via
# scripts/login_amazon.py — no credentials are stored here or read by the code.
